{
  "name": "winbill",
  "version": "2.0.0",
  "description": "Effortlessly generate professional, beautiful PDF invoices and receipts for your Node.js applications.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node -e \"require('fs').cpSync('src/assets', 'dist/assets', {recursive: true})\"",
    "prepublishOnly": "npm run build",
    "test": "jest",
    "demo": "npm run build && tsc -p tsconfig.demo.json && node .demo-out/demo.js",
    "advanced-demo": "npm run build && tsc -p tsconfig.demo.json && node .demo-out/advanced_demo.js"
  },
  "keywords": [
    "billing",
    "invoice",
    "pdf",
    "generator",
    "receipt"
  ],
  "author": "Satya Jugran",
  "license": "GPL-3.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/satya-jugran/winbill.git"
  },
  "funding": "https://ko-fi.com/satyajugran",
  "type": "commonjs",
  "dependencies": {
    "inversify": "^8.2.1",
    "pdfkit": "^0.19.1",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@swc/core": "^1.15.43",
    "@swc/jest": "^0.2.39",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.1",
    "@types/pdfkit": "^0.17.6",
    "@types/qrcode": "^1.5.6",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^7.0.2"
  }
}
